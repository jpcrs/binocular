{
  "name": "binocular",
  "displayName": "Binocular",
  "publisher": "jpcrs",
  "description": "Not exactly a telescope, but it's useful sometimes. Extension to search/navigate through files and workspaces.",
  "icon": "assets/binocular.png",
  "version": "0.2.0",
  "repository": {
    "url": "https://github.com/jpcrs/Binocular"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "binocular",
    "telescope",
    "fzf",
    "ripgrep",
    "grep",
    "fuzzy",
    "fuzzy finder",
    "search",
    "workspace"
  ],
  "activationEvents": [],
  "binocular": {
    "tui": {
      "minVersion": "0.2.0"
    }
  },
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "binocular.searchPath",
        "title": "Binocular: Search Paths",
        "category": "Binocular"
      },
      {
        "command": "binocular.searchPathConfigured",
        "title": "Binocular: Search Paths (Configured Folders)",
        "category": "Binocular"
      },
      {
        "command": "binocular.searchFiles",
        "title": "Binocular: Search Files",
        "category": "Binocular"
      },
      {
        "command": "binocular.searchFilesConfigured",
        "title": "Binocular: Search Files (Configured Folders)",
        "category": "Binocular"
      },
      {
        "command": "binocular.searchContent",
        "title": "Binocular: Search Content",
        "category": "Binocular"
      },
      {
        "command": "binocular.searchContentConfigured",
        "title": "Binocular: Search Content (Configured Folders)",
        "category": "Binocular"
      },
      {
        "command": "binocular.searchContentWithSelection",
        "title": "Binocular: Search Content With Selection",
        "category": "Binocular"
      },
      {
        "command": "binocular.searchContentWithSelectionConfigured",
        "title": "Binocular: Search Content With Selection (Configured Folders)",
        "category": "Binocular"
      },
      {
        "command": "binocular.searchDirectories",
        "title": "Binocular: Search Directories",
        "category": "Binocular"
      },
      {
        "command": "binocular.searchDirectoriesConfigured",
        "title": "Binocular: Search Directories (Configured Folders)",
        "category": "Binocular"
      },
      {
        "command": "binocular.runCustomCommand",
        "title": "Binocular: Run Custom Command",
        "category": "Binocular"
      }
    ],
    "configuration": {
      "title": "Binocular",
      "properties": {
        "binocular.binaryPath": {
          "type": "string",
          "default": "",
          "description": "Explicit path to the binocular binary. When empty, the extension falls back to PATH."
        },
        "binocular.searchPaths": {
          "type": "array",
          "default": [],
          "description": "List of folders to search via the 'Configured Folders' variants of Binocular commands.",
          "items": {
            "type": "string",
            "description": "Absolute path to a folder."
          }
        },
        "binocular.useExact": {
          "type": "boolean",
          "default": false,
          "description": "When enabled, adds the --exact flag to all Binocular search commands."
        },
        "binocular.customCommands": {
          "type": "array",
          "default": [],
          "description": "Custom commands that can be launched in a terminal editor from Binocular.",
          "items": {
            "type": "object",
            "required": [
              "title",
              "command"
            ],
            "properties": {
              "id": {
                "type": "string",
                "description": "Optional stable identifier for launching this custom command directly from keybindings or command arguments."
              },
              "title": {
                "type": "string"
              },
              "command": {
                "type": "string"
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": []
              },
              "cwd": {
                "type": "string",
                "enum": [
                  "activeWorkspace",
                  "firstWorkspace",
                  "activeFileDir"
                ],
                "default": "activeWorkspace"
              },
              "env": {
                "type": "object",
                "default": {}
              },
              "useShell": {
                "type": "boolean",
                "default": false
              }
            }
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npx @vscode/vsce package --no-dependencies",
    "deploy": "npx @vscode/vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "^1.96.0",
    "typescript": "^5.7.3"
  }
}